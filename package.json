{
  "name": "scale-inspector",
  "version": "1.0.0",
  "description": "HP-06 truck scale serial inspector — auto port/baud detection",
  "main": "scale-inspector.js",
  "scripts": {
    "start": "node scale-inspector.js",
    "build:win": "bun build scale-inspector.js --compile --target=bun-windows-x64 --outfile=dist/scale-inspector.exe",
    "build:linux": "bun build scale-inspector.js --compile --target=bun-linux-x64 --outfile=dist/scale-inspector-linux"
  },
  "dependencies": {
    "serialport": "^12.0.0"
  }
}
